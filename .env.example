# Kopieren nach `.env` und Werte setzen (nicht committen).
# Vite lädt diese Variablen und injiziert sie zur Build-/Dev-Zeit (siehe vite.config.ts).

# Ki-Backend: leer oder "gemini" = Google Gemini; "none" = KI im Client deaktivieren
AI_PROVIDER=

# Google Gemini – für KI-Zusammenfassungen und Textbearbeitung (optional, wenn AI_PROVIDER=gemini)
GEMINI_API_KEY=
